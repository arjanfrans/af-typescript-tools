{
  "name": "@arjanfrans/af-dotenv",
  "version": "0.0.2",
  "description": "Loads .env.local and .env.<NODE_ENV> into process.env, with real env variables taking priority",
  "repository": {
    "directory": "packages/dotenv"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/DotEnv.js",
      "types": "./dist/DotEnv.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test test/**/*.ts",
    "lint": "af-lint src",
    "lint:fix": "af-lint --fix src",
    "format": "af-format src test",
    "format:check": "af-format --check src test"
  },
  "devDependencies": {
    "@arjanfrans/af-codestyle": "0.0.2"
  }
}
